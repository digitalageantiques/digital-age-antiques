  "value_signals": [
    {
      "signal": "Cultural Memory",
      "meaning": "The object connects to a person, brand, era, technology, lifestyle, or shared memory."
    },
    {
      "signal": "Physical Authenticity",
      "meaning": "The object is real, material, original, and not only a digital image or reproduction."
    },
    {
      "signal": "Scarcity",
      "meaning": "The object is becoming harder to find, especially in clean, working, or complete condition."
    },
    {
      "signal": "Condition",
      "meaning": "The object is preserved, visually strong, working, or free from major damage."
    },
    {
      "signal": "Completeness",
      "meaning": "Box, manual, accessories, labels, stickers, inserts, or packaging are still present."
    },
    {
      "signal": "Provenance",
      "meaning": "The origin, ownership, purchase history, or context can be explained."
    },
    {
      "signal": "Display Value",
      "meaning": "The object can still create meaning in a home, studio, store, museum, or visual space."
    },
    {
      "signal": "Story Value",
